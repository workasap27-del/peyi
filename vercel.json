{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/scrape",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/generate",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/publish",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/close",
      "schedule": "5 12 * * *"
    }
  ]
}
